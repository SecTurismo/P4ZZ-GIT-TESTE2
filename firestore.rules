rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: admin, customer, employee, affiliate)
    //   - tenantId: string (required)
    //   - active: boolean (required)
    //
    // Collection: tenants/{tenantId}/data/{key}
    // Fields:
    //   - value: any (required)
    //   - updatedAt: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "geovannepazz2@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTenantMember(tenantId) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return data.id is string && 
             data.name is string && data.name.size() > 0 &&
             data.email is string &&
             data.role in ['admin', 'customer', 'employee', 'affiliate'] &&
             data.tenantId is string &&
             data.active is bool;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
    }

    match /tenants/{tenantId}/data/{key} {
      // Allow public read for MASTER settings to enable login page branding
      allow read: if (tenantId == 'MASTER' && key == 'settings_MASTER') || isAdmin() || isTenantMember(tenantId);
      allow write: if isAdmin() || isTenantMember(tenantId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
